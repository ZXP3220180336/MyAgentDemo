# MyAgentDemo 环境变量配置模板
# 复制此文件为 .env 并填入实际的API密钥

# ========== Tavily API 配置 ==========
# 用于网络搜索功能，注册地址：https://tavily.com
# 获取免费的API密钥用于测试
TAVILY_API_KEY=your_tavily_api_key_here

# ========== LLM API 配置（选择一种） ==========

# 选项一：DeepSeek API（推荐）
# 地址：https://api.deepseek.com
# 注册地址：https://platform.deepseek.com
# 只允许这两个model名（强制）：
# deepseek-chat（对应 V3.2 非思考版）
# deepseek-reasoner（对应 V3.2 思考版）
OPENAI_API_KEY=sk-your-deepseek-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL_ID=deepseek-chat

# 对应的Anthropic兼容接口配置（如需要）
ANTHROPIC_API_KEY=sk-your-deepseek-api-key-here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL_ID=deepseek-V3.2

# 选项二：Modelscope（国内用户）
# 地址：https://modelscope.cn
# OPENAI_API_KEY=your_modelscope_api_key
# OPENAI_BASE_URL=https://api-inference.modelscope.cn/v1/
# OPENAI_MODEL_ID=qwen-max

# 选项三：其他OpenAI兼容服务
# 例如：OpenAI官方、Azure OpenAI等
# OPENAI_API_KEY=your_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL_ID=gpt-4-turbo

# ========== 票务API配置 ==========
# 用于检查景点门票可用性，支持多种票务平台

# 票务API类型（mock: 模拟数据, meituan: 美团, ctrip: 携程, fliggy: 飞猪）
TICKET_API_TYPE=mock

# 票务API密钥（根据选择的API类型填写）
# 美团API密钥申请：https://open.meituan.com
# 携程API密钥申请：https://open.ctrip.com
# 飞猪API密钥申请：https://open.fliggy.com
TICKET_API_KEY=your_ticket_api_key_here

# 票务API基础URL（通常不需要修改，除非使用自定义部署）
# TICKET_BASE_URL=https://api.meituan.com/ticket/v1

# ========== 可选配置 ==========
# 以下配置可根据需要启用

# 代理设置（如在国内访问国际API）
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# 日志级别
# LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# 最大迭代次数（防止无限循环）
# MAX_ITERATIONS=10

# 超时设置（秒）
# REQUEST_TIMEOUT=30